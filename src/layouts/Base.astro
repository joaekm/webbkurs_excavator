---
export const prerender = false;
interface Props {
  title: string;
}
const { title } = Astro.props;
const users = Astro.locals.users ?? [];
const currentUserId = Astro.locals.currentUserId;
const backTo = Astro.url.pathname;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Grävmaskinskurs</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-title">🚜 Grävmaskinskurs</a>
      <nav class="site-nav">
        <a href="/">Moduler</a>
        <a href="/checklistor">Checklistor</a>
        {
          users.length > 0 && (
            <form class="user-switch" method="GET" action="/valj-anvandare">
              <label for="user-select">Användare:</label>
              <input type="hidden" name="to" value={backTo} />
              <select id="user-select" name="u" onchange="this.form.submit()">
                {users.map((u) => (
                  <option value={u.id} selected={u.id === currentUserId}>
                    {u.name}
                  </option>
                ))}
              </select>
            </form>
          )
        }
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      Personlig kurs — bevattningsdamm. Körs lokalt.
    </footer>
  </body>
</html>
